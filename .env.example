PORT=1234
# Upstash Redis — native Redis URL (rediss://:token@host:port)
# Required for multi-instance horizontal scaling via pub/sub.
# Leave blank to run single-instance mode (pub/sub disabled, all existing behaviour preserved).
# Get from: Upstash Console → your DB → "Connect" → "ioredis" tab
UPSTASH_REDIS_URL=
# Next.js API base (for snapshot save/load)
NEXTJS_API_URL=http://localhost:3000
NEXTJS_INTERNAL_SECRET=change-me-to-a-random-secret
